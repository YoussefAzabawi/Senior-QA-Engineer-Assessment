{
  "info": {
    "_postman_id": "53e090fe-6297-4d00-a449-b5e9de10d6b2",
    "name": "Pet Store Postman Collection",
    "description": "### Welcome to Postman! This is your first collection. \n\nCollections are your starting point for building and testing APIs. You can use this one to:\n\n• Group related requests\n• Test your API in real-world scenarios\n• Document and share your requests\n\nUpdate the name and overview whenever you’re ready to make it yours.\n\n[Learn more about Postman Collections.](https://learning.postman.com/docs/collections/collections-overview/)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "54382847",
    "_collection_link": "https://go.postman.co/collection/54382847-53e090fe-6297-4d00-a449-b5e9de10d6b2?source=collection_link"
  },
  "item": [
    {
      "name": "Pet Store",
      "item": [
        {
          "name": "Add New Pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has pet id\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.id).to.eql(123456);\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"petId\", pm.response.json().id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"id\": 123456,\r\n  \"category\": {\r\n    \"id\": 1,\r\n    \"name\": \"Dog\"\r\n  },\r\n  \"name\": \"Tommy\",\r\n  \"photoUrls\": [\r\n    \"string\"\r\n  ],\r\n  \"tags\": [\r\n    {\r\n      \"id\": 1,\r\n      \"name\": \"cute\"\r\n    }\r\n  ],\r\n  \"status\": \"available\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}v2/pet",
              "host": [
                "{{baseUrl}}v2"
              ],
              "path": [
                "pet"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Fetch Pet By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Correct pet returned\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.id).to.eql(Number(pm.environment.get(\"petId\")));\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}v2/pet/123456",
              "host": [
                "{{baseUrl}}v2"
              ],
              "path": [
                "pet",
                "123456"
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET Invalid ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.response.to.have.status(404);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}v2/pet/9999",
              "host": [
                "{{baseUrl}}v2"
              ],
              "path": [
                "pet",
                "9999"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}